    {
      "name": "2. GET - Consultas",
      "item": [
        {
          "name": "GET todos los datos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Es un array', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});",
                  "pm.test('Tiene elementos', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.length).to.be.greaterThan(0);",
                  "});",
                  "pm.test('Los elementos tienen los campos esperados', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json[0]).to.have.property('country');",
                  "    pm.expect(json[0]).to.have.property('year');",
                  "    pm.expect(json[0]).to.have.property('region');",
                  "    pm.expect(json[0]).to.have.property('cost_category');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/cost-of-healthy-diet-by-countries",
              "host": ["{{base_url}}"],
              "path": ["cost-of-healthy-diet-by-countries"]
            }
          },
          "response": []
        },
        {
          "name": "GET con rango de años",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Es un array', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});",
                  "pm.test('Todos los años están en el rango 2001-2020', () => {",
                  "    const json = pm.response.json();",
                  "    json.forEach(d => {",
                  "        pm.expect(d.year).to.be.within(2001, 2020);",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/cost-of-healthy-diet-by-countries?from=2001&to=2020",
              "host": ["{{base_url}}"],
              "path": ["cost-of-healthy-diet-by-countries"],
              "query": [
                { "key": "from", "value": "2001" },
                { "key": "to", "value": "2020" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET dato concreto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Es el dato correcto', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.country).to.eql('Spain');",
                  "    pm.expect(json.year).to.eql(2022);",
                  "});",
                  "pm.test('Tiene todos los campos', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('country_code');",
                  "    pm.expect(json).to.have.property('region');",
                  "    pm.expect(json).to.have.property('cost_healthy_diet_ppp_usd');",
                  "    pm.expect(json).to.have.property('cost_category');",
                  "});"
                ],
                "type": "text/javascript"
              }
